{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Screenshot Annotator",
  "version": "1.0.0",
  "identifier": "com.slaur.screenshot-annotator",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Screenshot Annotator",
        "width": 1100,
        "height": 750,
        "minWidth": 600,
        "minHeight": 400,
        "backgroundColor": "#1e1e1e",
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'; img-src 'self' data: blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
